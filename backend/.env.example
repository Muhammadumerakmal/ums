# --- Neon Postgres ---
DATABASE_URL="postgres://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"
DATABASE_URL_TEST="postgres://user:password@ep-xxxx-test.neon.tech/neondb_test?sslmode=require"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1h"
BCRYPT_ROUNDS="10"

# --- Server ---
PORT="4000"
# Origin allowed by CORS (the frontend dev server)
FRONTEND_ORIGIN="http://localhost:3000"

# --- AI assistant (OpenAI Agents SDK) ---
# Provide EITHER a Gemini key (routed via Google's OpenAI-compatible endpoint)
# OR an OpenAI key. If both are set, Gemini is used.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
# Optional model override.
# Defaults: "gemini-2.0-flash" when GEMINI_API_KEY is set, else "gpt-4o-mini".
AI_MODEL=""
