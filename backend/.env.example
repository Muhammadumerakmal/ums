# --- Neon Postgres ---
DATABASE_URL="postgres://user:password@ep-xxxx.neon.tech/neondb?sslmode=require"
DATABASE_URL_TEST="postgres://user:password@ep-xxxx-test.neon.tech/neondb_test?sslmode=require"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="1h"
BCRYPT_ROUNDS="10"

# --- Server ---
PORT="4000"
# Origin allowed by CORS (the frontend dev server)
FRONTEND_ORIGIN="http://localhost:3000"

# --- AI assistant (OpenAI Agents SDK) ---
# Provide ONE key. If several are set the priority is: OpenRouter > Gemini > OpenAI.
# OpenRouter and Gemini are reached through their OpenAI-compatible Chat Completions
# endpoints; tracing is disabled for both (traces would otherwise export to OpenAI).
OPENROUTER_API_KEY=""
GEMINI_API_KEY=""
OPENAI_API_KEY=""
# Optional model override — must be a model id the selected provider accepts.
# Defaults: "meta-llama/llama-3.1-8b-instruct" (OpenRouter),
#           "gemini-2.0-flash" (Gemini), "gpt-4o-mini" (OpenAI).
AI_MODEL=""
